<%- include('../partials/header.ejs') %>
<%- include('../partials/navbar.ejs') %>

<div class="container">
  <hr>

  <div class="card">
    <div class="card-header">
      <h2>Cadastrar Denúncia</h2>
    </div>

    <div class="card-body">

      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-warning">
          <h4 class="alert-heading">Aviso</h4>
          <p><%- message %></p>
        </div>
      <% } %>

      <form method="post" action="/denuncia/registrar" id="denunciaForm">

        <div class="row mb-3">

          <div class="col-md-6">
            <label class="form-label">Ano</label>

            <input
              class="form-control"
              type="number"
              name="year"
              value="<%= year %>"
              readonly
            >

            <small class="form-text text-muted">
              Ano em que a denúncia está sendo registrada.
            </small>
          </div>

          <div class="col-md-6">
            <label class="form-label">Número da Denúncia</label>

            <input
              class="form-control"
              type="number"
              name="number"
              value="<%= lastNumber %>"
              readonly
            >

            <small class="form-text text-muted">
              Número sequencial gerado automaticamente.
            </small>
          </div>

        </div>

        <div class="mb-3">

          <label class="form-label">Origem da Denúncia</label>

          <select
            class="form-control"
            name="registration_type"
            id="registration_type"
            required
          >

            <% for (let key in DENUNCIATION_SENDER) { %>
              <option value="<%= key %>">
                <%= DENUNCIATION_SENDER[key] %>
              </option>
            <% } %>

          </select>

          <small class="form-text text-muted">
            Informe como a denúncia foi recebida (telefone, presencialmente ou ofício).
          </small>

        </div>

        <div class="mb-3">

          <label class="form-label">Título</label>

          <input
            class="form-control"
            type="text"
            name="title"
            placeholder="Ex: Galinhas na Mineira"
            required
          >

          <small class="form-text text-muted">
            Um título breve e descritivo para identificar a denúncia.
          </small>

        </div>

        <div class="mb-3">

          <label class="form-label">Endereço do Local</label>

          <input
            class="form-control mb-2"
            type="text"
            name="endereco"
            placeholder="Nome da Rua (sem 'Rua', 'Av.', etc.)"
            required
          >

          <input
            class="form-control mb-2"
            type="text"
            name="numero"
            placeholder="Número da Casa"
            required
          >

          <input
            class="form-control mb-2"
            type="text"
            name="complemento"
            placeholder="Complemento (opcional)"
          >

          <%- include('../partials/districtAutocomplete', { districts }) %>

          <small class="form-text text-muted">
            Comece a digitar para ver sugestões de bairros cadastrados.
          </small>

        </div>

        <div class="mb-3">

          <label class="form-label">Descrição da Denúncia</label>

          <textarea
            class="form-control"
            name="description"
            placeholder="Descreva os detalhes da situação..."
            rows="4"
            required
          ></textarea>

          <small class="form-text text-muted">
            Descreva com o máximo de detalhes possíveis o que está acontecendo no local.
          </small>

        </div>

        <div class="d-flex justify-content-end">
          <button class="btn btn-success">
            <i class="fas fa-save"></i> Cadastrar Denúncia
          </button>
        </div>

      </form>

    </div>
  </div>

  <br>
</div>

<%- include('../partials/footer.ejs') %>