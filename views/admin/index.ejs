<%- include('../partials/header.ejs') %>
<%- include('../partials/navbar.ejs') %>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
	canvas {
	width: 100% !important;
	height: 300px !important;
	}
</style>
<div class="container">
	<hr>
	<div class="card">
		<div class="card-header">
			<h2>Painel Administrativo</h2>
		</div>
		<div class="card-body">
			<!-- FILTRO ANO -->
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h4>Visão Geral das Denúncias</h4>
				<div class="d-flex align-items-center">
					<label class="mr-2"><b>Ano</b></label>
					<select class="form-control" id="yearFilter" style="min-width:120px;">
						<% years.forEach(y => { %>
						<option value="<%= y %>" <%= year == y ? 'selected' : '' %>>
							<%= y %>
						</option>
						<% }) %>
					</select>
				</div>
			</div>
			<!-- CARDS -->
			<div class="row mb-4">
				<div class="col-md-3">
					<div class="card border-primary">
						<div class="card-body text-center">
							<h6>Total de Denúncias</h6>
							<h3><%= stats.total %></h3>
						</div>
					</div>
				</div>
				<div class="col-md-3">
					<div class="card border-warning">
						<div class="card-body text-center">
							<h6>Em Andamento</h6>
							<h3><%= stats.andamento %></h3>
						</div>
					</div>
				</div>
				<div class="col-md-3">
					<div class="card border-success">
						<div class="card-body text-center">
							<h6>Resolvidas</h6>
							<h3><%= stats.resolvidas %></h3>
						</div>
					</div>
				</div>
				<div class="col-md-3">
					<div class="card border-danger">
						<div class="card-body text-center">
							<h6>Sem Fiscal</h6>
							<h3><%= stats.semFiscal %></h3>
						</div>
					</div>
				</div>
			</div>
			<!-- GRÁFICO MÊS -->
			<div class="row mb-4">
				<div class="col-md-12">
					<div class="card">
						<div class="card-header">
							<h5>Denúncias por Mês</h5>
						</div>
						<div class="card-body">
							<canvas id="mesChart"></canvas>
						</div>
					</div>
				</div>
			</div>
			<!-- GRÁFICOS STATUS + BAIRROS -->
			<div class="row mb-4">
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5>Denúncias por Status</h5>
						</div>
						<div class="card-body">
							<canvas id="statusChart"></canvas>
						</div>
					</div>
				</div>
				<div class="col-md-6">
					<div class="card">
						<div class="card-header">
							<h5>Bairros com Mais Denúncias</h5>
						</div>
						<div class="card-body">
							<canvas id="bairroChart"></canvas>
						</div>
					</div>
				</div>
			</div>
			<!-- STATUS TABLE -->
			<div class="card mb-4">
				<div class="card-header">
					<h5>Status das Denúncias</h5>
				</div>
				<div class="card-body table-responsive">
					<table class="table table-striped table-hover">
						<thead class="thead-dark">
							<tr>
								<th>Status</th>
								<th>Quantidade</th>
							</tr>
						</thead>
						<tbody>
							<% statusStats.forEach(status => { %>
							<tr>
								<td><%= status.label %></td>
								<td><%= status.count %></td>
							</tr>
							<% }) %>
						</tbody>
					</table>
				</div>
			</div>
			<!-- ÚLTIMOS RELATÓRIOS -->
			<div class="card">
				<div class="card-header">
					<h5>Últimos Relatórios Adicionados</h5>
				</div>
				<div class="card-body table-responsive">
					<table class="table table-striped table-hover">
						<tbody>
							<% if(reports.length === 0){ %>
							<tr>
								<td>
									<div class="alert alert-info mb-0">
										Nenhum relatório registrado.
									</div>
								</td>
							</tr>
							<% } %>
							<% reports.slice(0,5).forEach(report => { %>
							<tr>
								<td>
									<b><%= report.denunciation.number %>/<%= report.denunciation.year %></b>
									<br>
									<small><%= report.denunciation.title %></small>
								</td>
								<td>
									<a href="/denuncia/<%= report.denunciation.id %>" class="btn btn-sm btn-primary">
									Ver
									</a>
								</td>
							</tr>
							<% }) %>
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
	<br>
</div>
<script>

	const yearFilter = document.getElementById('yearFilter')
	const validYears = <%- JSON.stringify(years) %>

	yearFilter.addEventListener('change', function () {
		const year = parseInt(this.value)
		if(!validYears.includes(year)) return
		window.location.href = `?year=${year}`
	})

	const meses = <%- JSON.stringify(meses) %>
	const bairros = <%- JSON.stringify(bairros) %>
	const statusStats = <%- JSON.stringify(statusStats) %>

	new Chart(document.getElementById('mesChart'), {
		type: 'line',
		data: {
			labels: ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'],
			datasets: [{
				label: 'Denúncias',
				data: meses,
				tension: 0.3
			}]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false
		}
	})

	new Chart(document.getElementById('statusChart'), {
		type: 'pie',
		data: {
			labels: statusStats.map(s => s.label),
			datasets: [{
				data: statusStats.map(s => s.count),
				backgroundColor: statusStats.map(s => s.color)
			}]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false
		}
	})

	new Chart(document.getElementById('bairroChart'), {
		type: 'bar',
		data: {
			labels: bairros.map(b => b.bairro),
			datasets: [{
				label: 'Denúncias',
				data: bairros.map(b => b.total)
			}]
		},
		options: {
			responsive: true,
			maintainAspectRatio: false
		}
	})
</script>
<%- include('../partials/footer.ejs') %>